func greet(name) {
    say "Ahoj " + name + "!"
}

func main() {
    set a = 10
    set b = 20
    set c = a + b
    say "Výsledek sčítání " + a + " a " + b + " je: " + c
    
    if c == 30 {
        say "Matematika funguje spolehlivě!"
    } else {
        say "Něco je špatně..."
    }
    
    greet("ze Solus Linuxu")
}