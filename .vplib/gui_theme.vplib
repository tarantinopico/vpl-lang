// Modern Dark Theme for VPL
func theme_bg() { return "#1e1e1e" }
func theme_surface() { return "#2d2d2d" }
func theme_primary() { return "#0078d4" }
func theme_text() { return "#ffffff" }
func theme_text_dim() { return "#cccccc" }
